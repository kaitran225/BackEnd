import mockit.*;
import org.junit.Test;
import static org.junit.Assert.assertEquals;

public class StaticMethodMocking {
    @Test
    public void testStaticMethod() {
        // Giả lập phương thức tĩnh
        new MockUp<MyStaticClass>() {
            @Mock
            public static int staticMethod() {
                return 42;  // Giả lập phương thức trả về giá trị 42
            }
        };

        // Kiểm tra giá trị trả về của phương thức tĩnh
        assertEquals(42, MyStaticClass.staticMethod());
    }
}
class MyStaticClass {
    public static int staticMethod() {
        return 10;  // Phương thức gốc sẽ trả về 10, nhưng bị mock trong test
    }
}
